#!/bin/sh

case "$1" in
    start)
        echo "🚀 正在启动全自动录像监控系统..."
        # 1. 必须先进入你存放脚本的目录
        cd /root
        # 2. 在后台(&)执行你的脚本，并将屏幕输出全部保存到日志文件中
        ./run_net_camera.sh > /userdata/camera_boot.log 2>&1 &
        ;;
    stop)
        echo "🛑 接收到打断指令，正在终止自动化进程..."
        # 1. 杀掉守护脚本本身
        killall run_net_camera.sh >/dev/null 2>&1
        # 2. 杀掉所有相关的 Python 进程 (set_wifi, main.py)
        killall python >/dev/null 2>&1
        # 3. 杀掉可能正在录像的 FFmpeg 底层
        killall ffmpeg >/dev/null 2>&1
        # 4. 安全停止底层的推流服务
        RkLunch-stop.sh >/dev/null 2>&1
        echo "✅ 自动化程序已彻底清除，硬件资源已释放，随时可以开始手动调试！"
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac
exit 0